# Upstash Redis (même instance qu'invoice-pwa)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Chiffrement (même clé qu'invoice-pwa)
ENCRYPTION_KEY=

# SMTP (même config qu'invoice-pwa)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Préfixe Redis factures : PROD ou TEST
INVOICE_PREFIX=PROD

# Email du praticien pour les alertes
PRATICIEN_EMAIL=cabinet@ouvertures-psy.online
